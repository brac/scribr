---
import { getCollection } from "astro:content";
import { published } from "../../../lib/published";
import { PROJECTS } from "../../../lib/projects";
import Base from "../../../layouts/Base.astro";
import TitleBlock from "../../../components/TitleBlock.astro";
import type { Cell } from "../../../components/TitleBlock.astro";

export async function getStaticPaths() {
  // All enum values, even currently-empty ones — stable URLs per SPEC.
  return PROJECTS.map((project) => ({ params: { project } }));
}

const { project } = Astro.params;

// Oldest first — the chronological, linkable project narrative (contrast with
// the index's newest-first interleave).
const posts = (await getCollection("log"))
  .filter(published)
  .filter((p) => p.data.project === project)
  .sort((a, b) => a.data.date.getTime() - b.data.date.getTime());

const isFieldNotes = project === "field-notes";
const displayName = isFieldNotes ? "FIELD NOTES" : project;

function metaLine(p: (typeof posts)[number]): string {
  const parts = [p.data.date.toISOString().slice(0, 10), p.data.project];
  if (p.data.phase !== undefined) {
    parts.push(`phase ${String(p.data.phase).padStart(2, "0")}`);
  }
  return parts.join(" · ");
}

const strip: Cell[] = [
  { label: "PROJECT", value: displayName!, marker: true },
  { label: "POSTS", value: String(posts.length) },
  { label: "FEED", value: "rss", href: `/log/${project}/rss.xml` },
];
---

<Base
  title={`${project} devlog — brac.dev`}
  description={`Devlog posts for ${project}, in build order.`}
  projectFeed={project}
>
  <TitleBlock cells={strip} />

  {
    posts.length === 0 ? (
      <p class="empty-state">No posts yet.</p>
    ) : (
      <ul class="entries">
        {posts.map((post) => (
          <li>
            <div class="entry-meta">{metaLine(post)}</div>
            <div class="entry-title">
              <a href={`/log/${post.id}/`}>{post.data.title}</a>
            </div>
            <p class="entry-summary">{post.data.summary}</p>
          </li>
        ))}
      </ul>
    )
  }
</Base>
