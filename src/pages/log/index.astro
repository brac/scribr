---
import { getCollection } from "astro:content";
import { published } from "../../lib/published";
import Base from "../../layouts/Base.astro";
import FilterChips from "../../components/FilterChips.tsx";
import type { ChipPost } from "../../components/FilterChips.tsx";

const posts = (await getCollection("log"))
  .filter(published)
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

// Pre-stringify into plain serializable objects before handing to the island —
// no CollectionEntry objects or Date instances cross the boundary.
const chipPosts: ChipPost[] = posts.map((post) => ({
  id: post.id,
  title: post.data.title,
  dateISO: post.data.date.toISOString(),
  dateDisplay: post.data.date.toISOString().slice(0, 10),
  project: post.data.project,
  phase: post.data.phase,
  summary: post.data.summary,
}));
---

<Base
  title="devlog — brac.dev"
  description="Devlog for brac.dev projects: decisions, failures, and numbers from each build phase."
>
  <h1>devlog</h1>
  <p class="lede">Decisions, failures, and numbers from each build phase.</p>
  {/* client:lazyidle (not client:idle): hydrates after load + double-rAF so
      the chips' JS fetches can never land inside the LCP window — see
      src/directives/lazyidle.mjs. The chips are server-rendered and fully
      visible either way; hydration only enables filtering. */}
  <FilterChips posts={chipPosts} client:lazyidle />
</Base>
