---
interface Benchmark {
  metric: string;
  value: string;
  target: string;
}

interface Props {
  benchmarks: Benchmark[];
}

const { benchmarks } = Astro.props;

// Every row gets a --pass-colored check in the leading column. This is a
// record of gates PASSED, not a live comparison: benchmarks in these posts are
// by contract the numbers that satisfied a phase's stop conditions, so the
// check asserts "this gate was met" rather than recomputing metric vs. target
// (which would need brittle parsing of mixed comparators like "<", "≤", ">=").
---

{
  benchmarks.length > 0 && (
    <div class="table-scroll">
      <table class="record-table">
        <caption>Benchmarks</caption>
        <thead>
          <tr>
            <th class="gate" aria-label="gate met">
              ✓
            </th>
            <th>Metric</th>
            <th>Value</th>
            <th>Target</th>
          </tr>
        </thead>
        <tbody>
          {benchmarks.map((b) => (
            <tr>
              <td class="gate">✓</td>
              <td>{b.metric}</td>
              <td class="val">{b.value}</td>
              <td>{b.target}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  )
}
