---
interface Decision {
  what: string;
  why: string;
  alternatives: string[];
}

interface Props {
  decisions: Decision[];
}

const { decisions } = Astro.props;
---

{
  decisions.length > 0 && (
    <div class="table-scroll">
      <table class="record-table">
        <caption>Decisions</caption>
        <thead>
          <tr>
            <th>Decision</th>
            <th>Why</th>
            <th>Alternatives rejected</th>
          </tr>
        </thead>
        <tbody>
          {decisions.map((d) => (
            <tr>
              <td class="val">{d.what}</td>
              <td>{d.why}</td>
              <td>{d.alternatives.join(", ")}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  )
}
