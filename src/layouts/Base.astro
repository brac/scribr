---
// Shared base layout: the <head> boilerplate every page uses. Styling is
// Phase 3 — this is browser-default HTML on purpose.
interface Props {
  title: string;
  description: string;
  // When set, adds a second RSS autodiscovery link for that project's feed.
  projectFeed?: string;
}

const { title, description, projectFeed } = Astro.props;

const canonical = new URL(Astro.url.pathname, Astro.site);
const globalFeed = new URL("rss.xml", Astro.site);
const projectFeedHref = projectFeed
  ? new URL(`log/${projectFeed}/rss.xml`, Astro.site)
  : undefined;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="canonical" href={canonical} />
    <link
      rel="alternate"
      type="application/rss+xml"
      title="brac.dev devlog"
      href={globalFeed}
    />
    {
      projectFeed && (
        <link
          rel="alternate"
          type="application/rss+xml"
          title={`brac.dev devlog — ${projectFeed}`}
          href={projectFeedHref}
        />
      )
    }
    <link rel="sitemap" href="/sitemap-index.xml" />
  </head>
  <body>
    <slot />
  </body>
</html>
