---
import type { CollectionEntry } from "astro:content";
import Base from "./Base.astro";
import TitleBlock from "../components/TitleBlock.astro";
import type { Cell } from "../components/TitleBlock.astro";
import DecisionTable from "../components/DecisionTable.astro";
import BenchmarkTable from "../components/BenchmarkTable.astro";

interface Props {
  post: CollectionEntry<"log">;
}

const { post } = Astro.props;
const { title, date, project, phase, summary, repo_ref, decisions, benchmarks } =
  post.data;

const displayDate = date.toISOString().slice(0, 10);
const isFieldNotes = project === "field-notes";

// The title block IS the post header metadata (replaces the old loose date/
// badge/phase <p> and the separate "code as of this post" line). field-notes
// posts carry no PHASE/REF cell — that absence is the differentiation — and
// their project cell reads FIELD NOTES (still linked; it's a real enum value).
const cells: Cell[] = [
  {
    label: "PROJECT",
    value: isFieldNotes ? "FIELD NOTES" : project,
    href: `/log/${project}/`,
    marker: true,
  },
];
if (phase !== undefined) {
  cells.push({ label: "PHASE", value: String(phase).padStart(2, "0") });
}
cells.push({ label: "DATE", value: displayDate });
if (repo_ref) {
  cells.push({
    label: "REF",
    value: repo_ref,
    href: `https://github.com/brac/${project}/tree/${repo_ref}`,
  });
}
---

<Base
  title={title}
  description={summary}
  projectFeed={project}
  ogImage={`/og/${post.id}.png`}
  article
>
  <article>
    <h1>{title}</h1>
    <TitleBlock cells={cells} />

    <div class="prose">
      <slot />
    </div>

    <DecisionTable decisions={decisions} />
    <BenchmarkTable benchmarks={benchmarks} />
  </article>
</Base>
